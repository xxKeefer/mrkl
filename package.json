{
  "name": "@xxkeefer/mrkl",
  "version": "0.5.3",
  "type": "module",
  "packageManager": "pnpm@10.14.0",
  "description": "Lightweight CLI tool for structured markdown task tracking",
  "bin": {
    "mrkl": "./dist/cli.mjs"
  },
  "scripts": {
    "build": "unbuild",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:update": "vitest run --update",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "changelog": "changelogen --output",
    "changelog:preview": "changelogen --no-output"
  },
  "keywords": [
    "cli",
    "task",
    "tracker",
    "markdown"
  ],
  "license": "MIT",
  "files": [
    "dist",
    "skills"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xxKeefer/mrkl.git"
  },
  "homepage": "https://github.com/xxKeefer/mrkl#readme",
  "bugs": {
    "url": "https://github.com/xxKeefer/mrkl/issues"
  },
  "dependencies": {
    "citty": "^0.1.6",
    "consola": "^3.4.0",
    "gray-matter": "^4.0.3",
    "smol-toml": "^1.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.3.3",
    "@vitest/ui": "3.2.4",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/headless": "^6.0.0",
    "changelogen": "^0.6.2",
    "eslint": "^10.0.3",
    "node-pty": "^1.1.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.56.1",
    "unbuild": "^3.3.1",
    "vitest": "^3.0.0"
  }
}
