{
  "name": "@xxkeefer/mrkl",
  "version": "0.4.1",
  "type": "module",
  "packageManager": "pnpm@10.14.0",
  "description": "Lightweight CLI tool for structured markdown task tracking",
  "bin": {
    "mrkl": "./dist/cli.mjs"
  },
  "scripts": {
    "build": "unbuild",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "changelog": "changelogen --output",
    "changelog:preview": "changelogen --no-output"
  },
  "keywords": [
    "cli",
    "task",
    "tracker",
    "markdown"
  ],
  "license": "MIT",
  "files": [
    "dist",
    "skills"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xxKeefer/mrkl.git"
  },
  "homepage": "https://github.com/xxKeefer/mrkl#readme",
  "bugs": {
    "url": "https://github.com/xxKeefer/mrkl/issues"
  },
  "dependencies": {
    "citty": "^0.1.6",
    "consola": "^3.4.0",
    "fzf": "^0.5.2",
    "gray-matter": "^4.0.3",
    "smol-toml": "^1.3.1"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "changelogen": "^0.6.2",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "unbuild": "^3.3.1",
    "vitest": "^3.0.0"
  }
}
